<?xml version="1.0" encoding="UTF-8" ?>
<!DOCTYPE mapper
        PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN"
        "https://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="co.kr.mmsoft.mmmemberservice.mybatis.mapper.ProviderMapper">
<!--    <select id="selectBlog" resultType="Blog">-->
<!--        select * from Blog where id = #{id}-->
<!--    </select>-->
    <!-- 이름으로 정보 가져오기 -->
    <select id = "findByProviderName" parameterType="String" resultType="co.kr.mmsoft.mmmemberservice.mybatis.domain.Provider">
        select provider_id, provider_name
        from provider
        where provider_name=#{providerName}
    </select>
    <select id = "findByProviderId" parameterType="int" resultType="co.kr.mmsoft.mmmemberservice.mybatis.domain.Provider">
        select provider_id, provider_name
        from provider
        where provider_id=#{providerId}
    </select>
</mapper>
